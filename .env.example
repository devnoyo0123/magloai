# OpenRouter API Key
# https://openrouter.ai/keys 에서 발급받으세요
OPENROUTER_API_KEY=your_api_key_here

# 사용할 모델 (선택사항, 기본값: nvidia/nemotron-3-super-120b-a12b:free)
MODEL_NAME=nvidia/nemotron-3-super-120b-a12b:free

# 다른 모델 옵션 (비용 및 품질 참고):
# MODEL_NAME=nvidia/nemotron-3-super-120b-a12b:free # 무료, 강력함, 한국어 우수
# MODEL_NAME=google/gemini-flash-1.5                # ~$0.075/1M, 빠름
# MODEL_NAME=anthropic/claude-3-haiku              # ~$0.25/1M, 정확함
# MODEL_NAME=openai/gpt-4o-mini                    # ~$0.15/1M, 균형있음
# MODEL_NAME=qwen/qwen-2.5-72b-instruct            # ~$0.04/1M, 저렴함

# Whisper 모델 (음성 인식용, 선택사항, 기본값: base)
WHISPER_MODEL=base

# Whisper 모델 옵션 (크기 및 성능):
# WHISPER_MODEL=base      # ~140MB, 빠름, 일반 용도 추천
# WHISPER_MODEL=small     # ~460MB, 조금 느림, 더 정확함
# WHISPER_MODEL=medium    # ~1.5GB, 느림, 고품질 (GPU 권장)
